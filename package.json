{
  "name": "aiml.js",
  "version": "1.1.0",
  "description": "Full-featured AIML 1.0/2.0 parser, validator and runtime for Node.js and browser",
  "author": "jesobreira",
  "homepage": "https://aiml.js.org/",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "aiml-validate": "dist/aiml-validate.mjs",
    "aiml-serve": "dist/aiml-serve.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "build:docs": "tsx scripts/build-docs.ts",
    "build:vercel": "node vercel-build.cjs",
    "validate": "tsx bin/aiml-validate.ts",
    "serve": "tsx bin/aiml-serve.ts",
    "chat:freeaiml": "tsx dev/freeaiml/chat.ts",
    "chat:rosie": "tsx dev/rosie/chat.ts",
    "chat:squarebear": "tsx dev/squarebear/chat.ts",
    "chat:alice": "tsx dev/alice/chat.ts",
    "app": "tsx app/server.ts"
  },
  "keywords": [
    "aiml",
    "chatbot",
    "nlp",
    "ai",
    "markup-language",
    "alice",
    "rosie"
  ],
  "license": "MIT",
  "dependencies": {
    "@xmldom/xmldom": "^0.9.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "marked": "^18.0.4",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.0.0"
  }
}

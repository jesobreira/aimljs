{
  "$schema": "https://typedoc.app/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "README.md",
  "name": "aiml.js",
  "includeVersion": true,
  "searchInComments": true,
  "categorizeByGroup": true,
  "categoryOrder": ["Bots", "Core", "Parsers", "Loaders", "Types", "*"],
  "groupOrder": ["Classes", "Interfaces", "Type Aliases", "Functions", "Variables", "*"],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "navigationLinks": {
    "GitHub": "https://github.com/jesobreira/aimljs"
  }
}
